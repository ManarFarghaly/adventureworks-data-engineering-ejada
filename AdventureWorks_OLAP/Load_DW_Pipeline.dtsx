          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{52645ABD-67C8-4A54-8952-6CBFF8C80E90}"
              SQLTask:SqlStatementSource="USE [AdventureWorks-DW];&#xA;GO&#xA;&#xA;-- Disable FK_FactSales_DimCustomer&#xA;IF EXISTS (&#xA;    SELECT 1 &#xA;    FROM sys.foreign_keys &#xA;    WHERE name = 'FK_FactSales_DimCustomer'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [Sales].[FactSales] DROP CONSTRAINT [FK_FactSales_DimCustomer];&#xA;END;&#xA;GO&#xA;&#xA;-- Disable FK_FactSales_DimDateOrder&#xA;IF EXISTS (&#xA;    SELECT 1 &#xA;    FROM sys.foreign_keys &#xA;    WHERE name = 'FK_FactSales_DimDateOrder'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [Sales].[FactSales] DROP CONSTRAINT [FK_FactSales_DimDateOrder];&#xA;END;&#xA;GO&#xA;&#xA;-- Disable FK_FactSales_DimDateShip&#xA;IF EXISTS (&#xA;    SELECT 1 &#xA;    FROM sys.foreign_keys &#xA;    WHERE name = 'FK_FactSales_DimDateShip'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [Sales].[FactSales] DROP CONSTRAINT [FK_FactSales_DimDateShip];&#xA;END;&#xA;GO&#xA;&#xA;-- Disable FK_FactSales_DimProduct&#xA;IF EXISTS (&#xA;    SELECT 1 &#xA;    FROM sys.foreign_keys &#xA;    WHERE name = 'FK_FactSales_DimProduct'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [Sales].[FactSales] DROP CONSTRAINT [FK_FactSales_DimProduct];&#xA;END;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Intial Load Mechanism\Reset Warehouse Data and Watermark"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
